# Talovi — environment variables
# Copy this file to .env and fill in the keys for the providers you want to use.
# Never commit .env to version control.
#
# Only the key for your active provider (config/talovi.config.js → provider) is required.
# Ollama runs locally and needs no API key.

# ── Claude (default provider) ─────────────────────────────────────────────────
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Gemini ────────────────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
# Also install the SDK: npm install @google/generative-ai
GEMINI_API_KEY=

# ── Grok ─────────────────────────────────────────────────────────────────────
# Get your key: https://console.x.ai/
# Also install the SDK: npm install openai
GROK_API_KEY=

# ── Ollama (local — no key required) ─────────────────────────────────────────
# Default base URL. Override if Ollama runs on a different host or port.
# Download Ollama: https://ollama.com/download
# OLLAMA_BASE_URL=http://localhost:11434
